# Copy to .env and paste your OpenRouter key. Then:
#   ollama serve && ollama pull embeddinggemma   # embeddings for memory
#   cargo run -- seed-user                        # load the dummy seed user
#   cargo run -- playground                       # open http://127.0.0.1:8088
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Provider for the CHAT model (embeddings always use Ollama embeddinggemma):
DITTOBENCH_PROVIDER=openrouter
# Production default chat model (mirror prod Ditto):
DITTOBENCH_MODEL=google/gemini-3.1-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
DITTOBENCH_DB=./dittobench.db

# Playground "Submit" tab — BYOK off-chain practice against the hosted validator.
# Your OPENROUTER_API_KEY (above) is forwarded per request for the generator +
# judge; the validator stores no keys.
# Base URL of dittobench-api. Defaults to the official hosted endpoint; set to a
# localhost api only for internal dev:
#   DITTOBENCH_API_URL=http://localhost:8000   # internal dev only
DITTOBENCH_API_URL=https://dittobench-api-22790208601.us-central1.run.app
# "local harness" target: the harness the validator runs against. The hosted
# validator must be able to REACH it, so expose your `serve` harness (e.g.
# `ngrok http 9000`) and put the public URL here:
DITTOBENCH_HARNESS_URL=http://localhost:9000
# "crate build" target: this crate's git location (on-chain / local Docker only):
DITTOBENCH_CRATE_GIT=https://github.com/ditto-assistant/dittobench-starter-kit
DITTOBENCH_CRATE_REF=main
