# Copy to .env and paste your OpenRouter key. Then:
#   ollama serve && ollama pull embeddinggemma   # embeddings for memory
#   cargo run -- seed-user                        # load the dummy seed user
#   cargo run -- playground                       # open http://127.0.0.1:8088
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Provider for the CHAT model (embeddings always use Ollama embeddinggemma):
DITTOBENCH_PROVIDER=openrouter
# Production default chat model (mirror prod Ditto):
DITTOBENCH_MODEL=google/gemini-3.1-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
DITTOBENCH_DB=./dittobench.db

# Playground "Submit" tab — proxies submissions to the hosted validator api.
# Base URL of dittobench-api (the playground backend calls it, avoiding CORS):
DITTOBENCH_API_URL=http://localhost:8000
# This crate's git location, cloned + built by the validator:
DITTOBENCH_CRATE_GIT=https://github.com/ditto-assistant/dittobench-starter-kit
DITTOBENCH_CRATE_REF=main
